{
   "name": "calculating-staking-rewards",
   "version": "1.0.0",
   "description": "Script for calculating staking rewards",
   "main": "index.js",
    "engines": {
      "node": ">=24.0.0"
   },
   "engineStrict": true,
   "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",

   "scripts": {
      "prepare-initial-data": "ts-node src/prepareInitialData.ts",
      "calculate-staking-rewards": "ts-node src/calculateRewards.ts",
      "sum-staking-rewards": "ts-node src/sumStakingRewards.ts",
      "build": "tsc",
      "format:fix": "prettier --write \"src/**/*.ts\"",
      "format:check": "prettier --check \"src/**/*.ts\"",
      "lint:fix": "eslint \"src/**/*.ts\" --fix",
      "lint:check": "eslint \"src/**/*.ts\"",
      "--- development scripts ---": "",
      "sync": "ts-node ./src/scripts/sync-artifacts.ts",
      "typechain-web3-v1": "typechain --target=web3-v1 --out-dir typechain-web3-v1 \"artifacts/!(build-info)/**/+([a-zA-Z0-9_]).json\" 1> nul",
      "artifacts": "npm-run-all sync typechain-web3-v1"
   },
   "dependencies": {
      "dotenv": "^17.0.0",
      "glob": "^8.0.3",
      "tsoa": "^3.5.2",
      "typescript-ioc": "^3.2.2",
      "web3": "^1",
      "winston": "^3.17.0",
      "bech32": "^2.0.0",
      "fast-sha256": "^1.3.0",
      "avalanche": "^3.15.4",
      "lodash": "^4.17.21",
      "json2csv": "^6.0.0-alpha.2",
      "axios": "^1.7.9",
      "csv-parse": "^5.6.0",
      "@flarenetwork/flarejs": "^1.2.1"
   },
   "prettier": "@flarenetwork/prettier-config-flare",
   "devDependencies": {
      "@eslint/compat": "^2.0.0",
      "@flarenetwork/eslint-config-flare": "^0.0.2",
      "@flarenetwork/prettier-config-flare": "^0.0.3",
      "@typechain/web3-v1": "3.1.0",
      "@types/node": "^22.0.0",
      "eslint": "^9.33.0",
      "eslint-config-prettier": "^10.0.0",
      "prettier": "^3.0.0",
      "prettier-plugin-solidity": "^2.1.0",
      "ts-node": "^10.9.2",
      "typechain": "5.1.2",
      "typescript": "^5.7.3",
      "npm-run-all": "^4.1.5",
      "@types/lodash": "^4.17.13"
   }
}
